# GeoGuard Ledger Backend — Environment Variables
# Copy this file to .env and fill in your values.

# Database
DATABASE_URL=postgresql+asyncpg://geoguard:geoguard_dev@localhost:5432/geoguard_ledger

# Soroban / Stellar
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
SOROBAN_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
CONTRACT_ID=

# API
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=["http://localhost:5173"]

# Authentication (Phase 3+)
# API_KEY_HEADER=X-API-Key
# JWT_SECRET_KEY=

# AI Model
AI_MODEL_VERSION=isoforest-v1
AI_ANOMALY_THRESHOLD=0.20

# Logging
LOG_LEVEL=INFO
