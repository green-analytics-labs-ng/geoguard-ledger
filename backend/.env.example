# GeoGuard Ledger — Backend Environment Variables
# Copy this file to .env and adjust values for your environment.
#
# All settings correspond to fields in app/config.py (pydantic-settings).
# Unset values fall back to the defaults defined in config.py.

# Database
# PostgreSQL connection string (asyncpg driver).
DATABASE_URL=postgresql+asyncpg://geoguard:geoguard_dev@localhost:5432/geoguard_ledger

# Soroban / Stellar
# RPC endpoint for the Stellar Soroban network.
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
# Network passphrase for transaction signing.
SOROBAN_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
# Deployed GeoGuardLedger smart contract ID (set after contract deployment).
CONTRACT_ID=

# API Server
API_HOST=0.0.0.0
API_PORT=8000
# JSON array of allowed CORS origins.
API_CORS_ORIGINS=["http://localhost:5173"]

# AI Model
# Version tag for the anomaly detection model.
AI_MODEL_VERSION=isoforest_v1
# Anomaly score threshold (0.0–1.0) for flagging datasets.
AI_ANOMALY_THRESHOLD=0.20

# Logging
# Log level: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO
